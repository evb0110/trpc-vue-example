{
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "framework": "vue",
  "rewrites": [
    {
      "source": "/api/trpc/:path*",
      "destination": "/api/trpc/[trpc]"
    }
  ],
  "functions": {
    "api/trpc/[trpc].ts": {
      "maxDuration": 10
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}